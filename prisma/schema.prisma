generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. DEPARTMENTS
model Department {
  department_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @unique @db.VarChar(100)
  description   String?  @db.Text
  status        String   @default("active") @db.VarChar(20) // active, inactive
  created_at    DateTime @default(now()) @db.Timestamp
  updated_at    DateTime @updatedAt @db.Timestamp
  created_by    String?  @db.Uuid

  doctors Doctor[]

  @@index([status])
  @@map("departments")
}

// 2. USERS
model User {
  user_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username   String    @unique @db.VarChar(50)
  password   String    @db.VarChar(255)
  role       String    @db.VarChar(20) // admin, receptionist
  is_active  Boolean   @default(true)
  last_login DateTime? @db.Timestamp
  created_at DateTime  @default(now()) @db.Timestamp
  updated_at DateTime  @updatedAt @db.Timestamp
  created_by String?   @db.Uuid

  created_by_user User?      @relation("UserCreatedBy", fields: [created_by], references: [user_id])
  users_created   User[]     @relation("UserCreatedBy")
  visits          Visit[]
  doctors         Doctor[]
  admin_logs      AdminLog[]
  bills_created   Bill[]     @relation("BillCreatedBy")
  patients_created Patient[] @relation("PatientCreatedBy")

  @@index([role])
  @@index([is_active])
  @@map("users")
}

// 3. DOCTORS
model Doctor {
  doctor_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name       String   @db.VarChar(50)
  last_name        String   @db.VarChar(50)
  specialization   String   @db.VarChar(100)
  department_id    String   @db.Uuid
  qualification    String   @db.VarChar(200)
  mobile           String   @db.VarChar(15)
  email            String   @unique @db.VarChar(100)  // BUG FIX: Added @unique
  consultation_fee Decimal  @default(0) @db.Decimal(10, 2)
  status           String   @default("active") @db.VarChar(20) // active, on_leave, inactive
  joining_date     DateTime @default(now()) @db.Date
  created_by       String?  @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamp
  updated_at       DateTime @updatedAt @db.Timestamp

  department  Department? @relation(fields: [department_id], references: [department_id])
  visits      Visit[]
  user        User?       @relation(fields: [created_by], references: [user_id])

  @@index([department_id])
  @@index([status])
  @@index([email])
  @@map("doctors")
}

// 4. PATIENTS
model Patient {
  patient_id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unique_id        String   @unique @db.VarChar(20)  // BUG FIX: Added @unique
  first_name       String   @db.VarChar(50)
  last_name        String   @db.VarChar(50)
  dob              DateTime @db.Date
  gender           String   @db.VarChar(10) // Male, Female, Other
  mobile           String   @db.VarChar(15)
  email            String?  @db.VarChar(100)
  address          String?  @db.VarChar(255)
  alternate_mobile String?  @db.VarChar(15)
  created_at       DateTime @default(now()) @db.Timestamp
  updated_at       DateTime @updatedAt @db.Timestamp
  created_by       String   @db.Uuid

  // BUG FIX: Added FK relation for created_by (was orphan without it)
  created_by_user User @relation("PatientCreatedBy", fields: [created_by], references: [user_id])

  visits                     Visit[]
  patient_allergies          PatientAllergy[]
  patient_chronic_conditions PatientChronicCondition[]

  @@index([mobile])
  @@index([unique_id])
  @@index([created_by])
  @@index([created_at])
  @@map("patients")
}

// 5. VISITS
model Visit {
  visit_id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vital_id         String   @unique @db.Uuid  // Added @unique — one-to-one
  bill_id          String   @unique @db.Uuid  // Added @unique — one-to-one
  patient_id       String   @db.Uuid
  doctor_id        String?  @db.Uuid
  consultation_fee Decimal  @db.Decimal(10, 2)
  visit_type       String   @default("OPD") @db.VarChar(50)
  visit_date       DateTime @default(now()) @db.Timestamp
  created_by       String   @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamp

  patient         Patient @relation(fields: [patient_id], references: [patient_id])
  doctor          Doctor? @relation(fields: [doctor_id], references: [doctor_id])
  created_by_user User    @relation(fields: [created_by], references: [user_id])

  vitals Vital @relation(fields: [vital_id], references: [vital_id])
  bill   Bill  @relation(fields: [bill_id], references: [bill_id])

  @@index([patient_id])
  @@index([doctor_id])
  @@index([created_by])
  @@index([visit_date])
  @@index([visit_type])
  @@map("visits")
}

// 6. VITALS
model Vital {
  vital_id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blood_pressure String?  @db.VarChar(20)
  heart_rate     Int?
  age            Int?
  temperature    Decimal? @db.Decimal(4, 1)
  weight         Decimal? @db.Decimal(5, 2)
  height         Decimal? @db.Decimal(5, 2)
  bmi            Decimal? @db.Decimal(5, 2)
  bmr            Decimal? @db.Decimal(5, 2)
  recorded_at    DateTime @default(now()) @db.Timestamp
  visits         Visit[]

  @@map("vitals")
}

// 7. ALLERGIES
model Allergy {
  allergy_id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  allergy_name String @unique @db.VarChar(100)  // BUG FIX: Added @unique
  category     String @db.VarChar(10) // drug, food, other

  patient_allergies PatientAllergy[]

  @@map("allergies")
}

model PatientAllergy {
  patient_id    String  @db.Uuid
  allergy_id    String  @db.Uuid
  specific_note String? @db.VarChar(255)

  patient Patient @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade)
  allergy Allergy @relation(fields: [allergy_id], references: [allergy_id])

  @@id([patient_id, allergy_id])
  @@map("patient_allergies")
}

// 8. CHRONIC CONDITIONS
model ChronicCondition {
  condition_id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  condition_name String @unique @db.VarChar(50)

  patient_chronic_conditions PatientChronicCondition[]

  @@map("chronic_conditions")
}

model PatientChronicCondition {
  patient_id          String  @db.Uuid
  condition_id        String  @db.Uuid
  other_specific_note String? @db.VarChar(255)

  patient   Patient          @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade)
  condition ChronicCondition @relation(fields: [condition_id], references: [condition_id])

  @@id([patient_id, condition_id])
  @@map("patient_chronic_conditions")
}

// 9. BILLS
model Bill {
  bill_id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consultation_fee Decimal  @db.Decimal(10, 2)
  extra_charges    Decimal  @default(0) @db.Decimal(10, 2)
  total_amount     Decimal  @default(0) @db.Decimal(10, 2)
  payment_status   String   @default("pending") @db.VarChar(20) // paid, pending, partial
  payment_method   String?  @db.VarChar(20) // cash, card, insurance
  bill_date        DateTime @default(now()) @db.Timestamp
  created_by       String?  @db.Uuid

  created_by_user User?   @relation("BillCreatedBy", fields: [created_by], references: [user_id])
  visits          Visit[]

  @@index([payment_status])
  @@index([created_by])
  @@map("bills")
}

// 10. ADMIN LOGS
model AdminLog {
  log_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id    String   @db.Uuid
  action_type String   @db.VarChar(50)
  target_type String   @db.VarChar(50)
  target_id   String   @db.Uuid
  details     String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamp

  admin User @relation(fields: [admin_id], references: [user_id])

  @@index([admin_id])
  @@index([created_at])
  @@map("admin_logs")
}
