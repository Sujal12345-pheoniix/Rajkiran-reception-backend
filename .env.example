# .env.example for Backend (reception-backend-main)
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"
JWT_SECRET="use-a-secure-random-32-character-secret-key-in-prod"
JWT_REFRESH_SECRET="use-another-secure-random-32-character-key"
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"
NODE_ENV="development" # or "production"
PORT=3001
HOST="0.0.0.0"
